# Cesium Ion access token (optional — enables high-res satellite imagery)
# Get a free token at https://cesium.com/ion/signup
CESIUM_ION_TOKEN=

# GDELT API (free, no key needed — leave blank)
# Used for news event geocoding
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc

# Open Government Data India API (optional)
# Register at https://data.gov.in
OGD_API_KEY=

# CPCB API endpoint (public, no key needed)
CPCB_API_URL=https://app.cpcbccr.com

# IMD API endpoint (public, no key needed)
IMD_API_URL=https://mausam.imd.gov.in

# Custom tile server URL (optional — override default map tiles)
TILE_SERVER_URL=

# Analytics (optional — for self-hosted tracking)
ANALYTICS_ENDPOINT=
ANALYTICS_KEY=

# App configuration
APP_TITLE=Project Arjun — God's Eye India
APP_ENV=development
